# ──────────────────────────────────────────────────────────────────────────────
# Bolna Voice Runtime Engine — Environment Variables Template
# Copy this file to '.env' in the same directory and fill in your credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/bolna"

# ── Server Configuration (OPTIONAL / DEFAULTS) ───────────────────────────────
# The local port the Express server will listen on. Defaults to 3001.
PORT=3001
# Environment mode: development | production | test. Defaults to development.
NODE_ENV=development
# Logging verbosity: debug | info | warn | error. Defaults to debug.
LOG_LEVEL=debug
# The URL of the running Next.js dashboard client frontend. Defaults to http://localhost:3000.
FRONTEND_URL=http://localhost:3000

# ── Vobiz Telephony Credentials (REQUIRED) ──────────────────────────────────
# Your Vobiz Account Auth ID (from Vobiz dashboard).
VOBIZ_AUTH_ID=your_auth_id
# Your Vobiz Account Auth Token (from Vobiz dashboard).
VOBIZ_AUTH_TOKEN=your_token
# Your purchased E.164 phone number from Vobiz, e.g., +1234567890.
VOBIZ_FROM_NUMBER=+1234567890
# The Vobiz API endpoint URL.
VOBIZ_API_URL=https://api.vobiz.ai/api/v1

# ── AI Model Providers (At least one is REQUIRED) ───────────────────────────
# Google Gemini API configurations. Required if using Gemini voice agents.
GEMINI_API_KEY=your_gemini_api_key
# The Gemini Multimodal Live API endpoint version. Must be 'v1alpha'.
GEMINI_API_VERSION=v1alpha
# Gemini model for realtime voice interactions. Defaults to gemini-2.0-flash.
GEMINI_REALTIME_MODEL=gemini-2.0-flash

# OpenAI API configurations. Required if using OpenAI voice agents (fallback).
OPENAI_API_KEY=sk-...
# OpenAI model for realtime voice interactions. Defaults to gpt-4o-realtime-preview.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# ── Networking & Webhook Tunnels (CRITICAL for Vobiz callback) ──────────────
# Publicly accessible URL (e.g. ngrok tunnel) pointing to your local port 3001.
# This is critical so Vobiz can route webhook events (answer, status, hangup) to the server.
PUBLIC_URL=https://your-public-url.ngrok-free.app

# Optional: Ngrok autostart token. If supplied, the server can establish its own tunnel.
NGROK_AUTH_TOKEN=

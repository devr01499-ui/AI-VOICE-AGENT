// Claritiy Voice Runtime Engine — Database Schema
// Provider: SQLite for local dev. Switch to postgresql for production.
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// IDENTITY & AUTH
// ─────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  fullName       String   @map("full_name")
  accountType           String   @default("free") @map("account_type") // free | developer | professional | enterprise
  billingBalance        Float    @default(100.0) @map("billing_balance")
  contactNumber         String?  @map("contact_number")
  geminiApiKey          String?  @map("gemini_api_key")
  callingBalanceMinutes Float    @default(10.0) @map("calling_balance_minutes")
  totalMinutesConsumed  Float    @default(0.0) @map("total_minutes_consumed")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  apiKeys              ApiKey[]
  agents               Agent[]
  calls                Call[]
  phoneNumbers         PhoneNumber[]
  knowledgeBases       KnowledgeBase[]
  batches              Batch[]
  subAccounts          SubAccount[]
  webhooks             Webhook[]
  providerCredentials  ProviderCredential[]
  callSessions         CallSession[]

  @@map("users")
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  keyHash     String    @map("key_hash")
  keyPrefix   String    @map("key_prefix") // blna_live_ | blna_test_ | sa_
  name        String    @default("Default API Key")
  scopes      String    @default("[]") // JSON array of permission scopes
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
  @@map("api_keys")
}

// ─────────────────────────────────────────────
// AGENTS
// ─────────────────────────────────────────────

model Agent {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  description    String?
  agentType      String   @default("conversational") @map("agent_type") // conversational | task_oriented
  status         String   @default("draft") // draft | active | inactive
  agentConfig    String   @default("{}") @map("agent_config") // JSON: voice_config, llm_config, asr_config, etc.
  workspaceId    String?  @map("workspace_id")
  model          String?
  voiceName      String?  @map("voice_name")
  systemVoice    String   @default("Puck") @map("system_voice")
  temperature    Float?   @default(0.7)
  systemPrompt   String?  @map("system_prompt")
  version        Int      @default(1)
  tags           String   @default("[]") // JSON array
  flowGraph      String?  @map("flow_graph")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions       AgentVersion[]
  calls          Call[]
  phoneNumbers   PhoneNumber[]
  batches        Batch[]
  inboundConfigs InboundConfig[]
  voiceSessions  VoiceSession[]
  callSessions   CallSession[]
  kbLinks        AgentKnowledgeBase[]

  // Knowledge base relationships stored as JSON array of IDs in agentConfig
  // for simplicity — a proper join table can be added later.

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("agents")
}

model AgentVersion {
  id          String   @id @default(uuid())
  agentId     String   @map("agent_id")
  version     Int
  agentConfig String   @map("agent_config") // JSON snapshot
  changelog   String?
  createdAt   DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, version])
  @@index([agentId])
  @@map("agent_versions")
}

// ─────────────────────────────────────────────
// CALLS & EXECUTIONS
// ─────────────────────────────────────────────

model Call {
  id                   String    @id @default(uuid())
  agentId              String    @map("agent_id")
  userId               String    @map("user_id")
  batchId              String?   @map("batch_id")
  recipientPhoneNumber String    @map("recipient_phone_number")
  fromPhoneNumber      String?   @map("from_phone_number")
  status               String    @default("queued") // queued | ringing | in_progress | completed | failed | no_answer | busy
  callDirection        String    @default("outbound") @map("call_direction") // inbound | outbound
  startTime            DateTime? @map("start_time")
  endTime              DateTime? @map("end_time")
  durationSeconds      Int?      @map("duration_seconds")
  telemetryId          String?   @map("telemetry_id")
  providerCallSid      String?   @unique @map("provider_call_sid")
  userData             String    @default("{}") @map("user_data") // JSON
  webhookUrl           String?   @map("webhook_url")
  recordingEnabled     Boolean   @default(true) @map("recording_enabled")
  maxDuration          Int       @default(1800) @map("max_duration")
  createdAt            DateTime  @default(now()) @map("created_at")

  agent              Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch              Batch?             @relation(fields: [batchId], references: [id], onDelete: SetNull)
  execution          Execution?
  voiceSessions      VoiceSession[]
  transcriptSegments TranscriptSegment[]
  callEvents         CallEvent[]

  @@index([agentId])
  @@index([userId])
  @@index([status])
  @@index([batchId])
  @@index([createdAt])
  @@map("calls")
}

model Execution {
  id            String   @id @default(uuid())
  callId        String   @unique @map("call_id")
  transcript    String   @default("[]") // JSON array of transcript turns
  recordingUrl  String?  @map("recording_url")
  sentimentScore Float?  @map("sentiment_score")
  outcome       String?  // successful | unsuccessful | unknown
  costBreakdown String   @default("{}") @map("cost_breakdown") // JSON
  metadata      String   @default("{}") // JSON
  createdAt     DateTime @default(now()) @map("created_at")

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@map("executions")
}

// ─────────────────────────────────────────────
// PHONE NUMBERS
// ─────────────────────────────────────────────

model PhoneNumber {
  id                String   @id @default(uuid())
  phoneNumber       String   @unique @map("phone_number") // E.164 format
  userId            String   @map("user_id")
  assignedAgentId   String?  @map("assigned_agent_id")
  countryCode       String   @map("country_code")
  type              String   @default("local") // local | toll_free
  telephonyProvider String   @map("telephony_provider") // twilio | plivo | exotel
  capabilities      String   @default("[\"voice\"]") // JSON array
  status            String   @default("active") // active | inactive
  monthlyCost       Float    @default(1.0) @map("monthly_cost")
  purchasedAt       DateTime @default(now()) @map("purchased_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent? @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)

  inboundConfigs InboundConfig[]

  @@index([userId])
  @@index([assignedAgentId])
  @@map("phone_numbers")
}

// ─────────────────────────────────────────────
// KNOWLEDGE BASE
// ─────────────────────────────────────────────

model KnowledgeBase {
  id          String   @id @default(uuid())
  name        String
  contentText String   @map("content_text")
  sizeChars   Int      @default(0) @map("size_chars")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kbChunks KnowledgeBaseChunk[]
  agentLinks AgentKnowledgeBase[]

  @@index([userId])
  @@map("knowledge_bases")
}

model AgentKnowledgeBase {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  kbId      String   @map("kb_id")
  createdAt DateTime @default(now()) @map("created_at")

  agent Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  kb    KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)

  @@unique([agentId, kbId])
  @@index([agentId])
  @@index([kbId])
  @@map("agent_knowledge_bases")
}

model KnowledgeBaseChunk {
  id        String   @id @default(uuid())
  kbId      String   @map("kb_id")
  content   String   @map("content")
  embedding Unsupported("vector(3072)")?
  metadata  String   @default("{}") @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")

  kb KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)

  @@index([kbId])
  @@map("kb_chunks")
}

// ─────────────────────────────────────────────
// BATCH CAMPAIGNS
// ─────────────────────────────────────────────

model Batch {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  agentId         String    @map("agent_id")
  name            String
  status          String    @default("scheduled") // scheduled | running | paused | completed | cancelled
  totalRecipients Int       @default(0) @map("total_recipients")
  completedCount  Int       @default(0) @map("completed_count")
  failedCount     Int       @default(0) @map("failed_count")
  scheduleConfig  String    @default("{}") @map("schedule_config") // JSON
  throttleConfig  String    @default("{}") @map("throttle_config") // JSON
  retryConfig     String    @default("{}") @map("retry_config") // JSON
  createdAt       DateTime  @default(now()) @map("created_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent      Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  recipients BatchRecipient[]
  calls      Call[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@map("batches")
}

model BatchRecipient {
  id            String    @id @default(uuid())
  batchId       String    @map("batch_id")
  phoneNumber   String    @map("phone_number")
  userData      String    @default("{}") @map("user_data") // JSON
  status        String    @default("pending") // pending | in_progress | completed | failed
  callId        String?   @map("call_id")
  attempts      Int       @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([status])
  @@map("batch_recipients")
}

// ─────────────────────────────────────────────
// MULTI-TENANCY
// ─────────────────────────────────────────────

model SubAccount {
  id            String   @id @default(uuid())
  parentUserId  String   @map("parent_user_id")
  name          String
  email         String
  apiKeyHash    String?  @map("api_key_hash")
  quotaLimits   String   @default("{}") @map("quota_limits") // JSON
  currentUsage  String   @default("{}") @map("current_usage") // JSON
  billingMode   String   @default("parent_pays") @map("billing_mode") // parent_pays | self_pays
  webhookUrl    String?  @map("webhook_url")
  status        String   @default("active") // active | suspended
  createdAt     DateTime @default(now()) @map("created_at")

  parentUser User @relation(fields: [parentUserId], references: [id], onDelete: Cascade)

  @@index([parentUserId])
  @@map("sub_accounts")
}

// ─────────────────────────────────────────────
// WEBHOOKS
// ─────────────────────────────────────────────

model Webhook {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventType String   @map("event_type") // call.* | agent.* | batch.* | kb.*
  url       String
  secretKey String   @map("secret_key")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs WebhookLog[]

  @@index([userId])
  @@index([eventType])
  @@map("webhooks")
}

model WebhookLog {
  id             String   @id @default(uuid())
  webhookId      String   @map("webhook_id")
  eventId        String   @map("event_id")
  status         String   // success | failed
  httpStatus     Int?     @map("http_status")
  responseTimeMs Int?     @map("response_time_ms")
  errorMessage   String?  @map("error_message")
  attemptNumber  Int      @default(1) @map("attempt_number")
  deliveredAt    DateTime @default(now()) @map("delivered_at")

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([deliveredAt])
  @@map("webhook_logs")
}

// ─────────────────────────────────────────────
// SIP TRUNKS
// ─────────────────────────────────────────────

model SipTrunk {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  sipUri         String   @map("sip_uri")
  username       String?
  password       String?  // encrypted
  outboundProxy  String?  @map("outbound_proxy")
  codecs         String   @default("[\"PCMU\",\"PCMA\"]") // JSON array
  dtmfMode       String   @default("rfc2833") @map("dtmf_mode")
  status         String   @default("active") // active | inactive
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("sip_trunks")
}

// ─────────────────────────────────────────────
// INBOUND CONFIGURATION
// ─────────────────────────────────────────────

model InboundConfig {
  id                  String   @id @default(uuid())
  phoneNumberId       String   @map("phone_number_id")
  agentId             String   @map("agent_id")
  businessHours       String   @default("{}") @map("business_hours") // JSON
  outsideHoursAction  String   @default("voicemail") @map("outside_hours_action") // voicemail | forward_to | agent
  voicemailConfig     String   @default("{}") @map("voicemail_config") // JSON
  callRouting         String   @default("{}") @map("call_routing") // JSON
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  phoneNumber PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  agent       Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([phoneNumberId])
  @@index([agentId])
  @@map("inbound_configs")
}

// ─────────────────────────────────────────────
// VOICE SESSIONS
// ─────────────────────────────────────────────

model VoiceSession {
  id              String    @id @default(uuid())
  callId          String    @map("call_id")
  agentId         String    @map("agent_id")
  vobizCallUuid   String?   @map("vobiz_call_uuid")
  openaiSessionId String?   @map("openai_session_id")
  status          String    @default("initializing") // initializing | active | closing | closed | error
  voiceConfig     String    @default("{}") @map("voice_config") // JSON
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationMs      Int?      @map("duration_ms")
  latencyAvgMs    Float?    @map("latency_avg_ms")
  metadata        String    @default("{}") // JSON
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  call  Call  @relation(fields: [callId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@index([agentId])
  @@index([status])
  @@map("voice_sessions")
}

model TranscriptSegment {
  id             String   @id @default(uuid())
  callId         String   @map("call_id")
  speaker        String   // agent | user
  content        String
  startTime      Float    @map("start_time") // seconds from call start
  endTime        Float?   @map("end_time")
  sequenceNumber Int      @map("sequence_number")
  confidence     Float?   // ASR confidence
  metadata       String   @default("{}") // JSON
  createdAt      DateTime @default(now()) @map("created_at")

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@index([callId, sequenceNumber])
  @@map("transcript_segments")
}

model CallEvent {
  id        String   @id @default(uuid())
  callId    String   @map("call_id")
  eventType String   @map("event_type") // state_change | error | tool_call | interruption | etc.
  payload   String   @default("{}") // JSON
  timestamp DateTime @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@index([callId, eventType])
  @@map("call_events")
}

model ProviderCredential {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  providerType String    @map("provider_type") // vobiz | openai | deepgram | elevenlabs
  credentials  String    // encrypted JSON
  isActive     Boolean   @default(true) @map("is_active")
  lastTestedAt DateTime? @map("last_tested_at")
  healthStatus String    @default("unknown") @map("health_status") // healthy | degraded | down | unknown
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerType])
  @@map("provider_credentials")
}

model RuntimeMetric {
  id          String   @id @default(uuid())
  callId      String?  @map("call_id")
  metricType  String   @map("metric_type") // latency | audio_quality | error_rate
  value       Float
  unit        String   // ms | percent | count
  tags        String   @default("{}") // JSON key-value pairs
  recordedAt  DateTime @default(now()) @map("recorded_at")

  @@index([metricType])
  @@index([callId])
  @@index([recordedAt])
  @@map("runtime_metrics")
}


model CallSession {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  agentId        String    @map("agent_id")
  callId         String    @unique @map("call_id")
  status         String    @default("queued")
  transcript     String    @default("[]") @map("transcript") // JSON array of timestamps and content
  userSentiment  String?   @map("user_sentiment")
  recordingUrl   String?   @map("recording_url")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("call_sessions")
}
